FROM node:22-bookworm-slim

# GHCR links new packages to the source repo when Actions pushes with GITHUB_TOKEN.
ARG IMAGE_SOURCE=https://github.com/db-aeon/joshu-oss
LABEL org.opencontainers.image.source=${IMAGE_SOURCE}

WORKDIR /app
COPY packages/voice-realtime/ ./
RUN npm install && npm run build
EXPOSE 8792
CMD ["node", "dist/index.js"]
