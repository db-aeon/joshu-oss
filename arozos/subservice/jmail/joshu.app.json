{
  "id": "jmail",
  "name": "jMail",
  "version": "0.1.0",
  "license": "AGPL-3.0",
  "publisher": "joshu",
  "entry": "jmail/index.html",
  "apiPrefix": "/joshu/api/jmail",
  "description": "Nylas agent inbox",
  "data": {
    "uses": ["mail", "connections", "memory"],
    "mail": { "accounts": "any" }
  },
  "agent": {
    "skill": "jmail-gui",
    "usesSkills": ["joshu-mail"],
    "headless": false,
    "guiActions": [
      { "name": "openCompose", "description": "Open compose pane with optional draft fields" },
      { "name": "openThread", "description": "Focus a message/thread by id" },
      { "name": "searchMail", "description": "Run inbox search and update the message list" },
      { "name": "switchInbox", "description": "Switch active mailbox tab" },
      { "name": "startReply", "description": "Open reply compose for selected thread" },
      { "name": "refreshInbox", "description": "Reload inbox list" },
      { "name": "syncMirror", "description": "Sync local mail mirror" },
      { "name": "openSetup", "description": "Open setup pane" }
    ],
    "voiceCommands": [
      { "name": "compose", "phrases": ["new email", "compose", "write an email"], "action": "openCompose" },
      {
        "name": "search",
        "phrases": ["search mail", "find email", "search for"],
        "action": "searchMail",
        "params": ["query"]
      }
    ],
    "actions": [
      { "name": "connectorsStatus", "description": "Mail connector registry and mirror health" },
      { "name": "syncMirror", "description": "Sync local mail mirror (cache tier)" }
    ]
  }
}
