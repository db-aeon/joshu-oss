# Per-customer VPS instance — copy to /etc/joshu/instance.env (mode 600)

# --- Standalone self-host (no control plane) ---
# JOSHU_STANDALONE=1

# --- Identity ---
JOSHU_INSTANCE_ID=
INSTANCE_AGENT_TOKEN=
CONTROL_PLANE_URL=https://admin.example.com
CUSTOMER_DOMAIN=customer.sandbox.example.com
VPS_IPV4=

# --- Release (public OSS images — keep in sync with deploy/RELEASE.json) ---
JOSHU_RELEASE_VERSION=0.1.29
JOSHU_RELEASE_CHANNEL=stable
JOSHU_IMAGE_REF=ghcr.io/db-aeon/joshu-oss:0.1.29
JOSHU_VOICE_IMAGE_REF=ghcr.io/db-aeon/joshu-oss-voice-realtime:0.1.29
HERMES_AGENT_REF=a91a57fa5a13d516c38b07a141a9ce8a3daabeb0

# --- Joshu / ArozOS (match VPS parity) ---
PUBLIC_BASE_PATH=/joshu
HOST=127.0.0.1
PORT=8788
PUBLIC_AROZ_PORT=8787
AROZOS_ENABLED=true
CAMOFOX_URL=http://127.0.0.1:9377
CAMOFOX_AUTO_RESTART=false
ENABLE_VNC=1
VNC_RESOLUTION=1024x768
NOVNC_URL=/novnc
NOVNC_PROXY_TARGET=http://127.0.0.1:6080
NOVNC_CLIENT_PATH=/novnc
BROWSER_IDLE_TIMEOUT_MS=0
SESSION_TIMEOUT_MS=1800000
CAMOFOX_START_URL=https://news.google.com/
HERMES_BIN=/opt/hermes-agent/venv/bin/hermes
HERMES_API_BASE_URL=http://127.0.0.1:8642
# Generate one random per-instance gateway secret and set both variables to the
# same value. Joshu sends HERMES_API_KEY; Hermes gateway checks API_SERVER_KEY.
HERMES_API_KEY=change-me-production
API_SERVER_KEY=change-me-production
HERMES_API_AUTO_START=true
# Hermes web dashboard — browser admin UI (cron, skills, MCP, kanban).
# VPS default: own hostname via Caddy → :9119 at site root (no /joshu/hermes-admin proxy).
# HERMES_DASHBOARD_DOMAIN defaults to hermes-admin.${CUSTOMER_DOMAIN} — needs DNS A record.
JOSHU_HERMES_DASHBOARD_ENABLED=true
JOSHU_HERMES_DASHBOARD_DIRECT=true
HERMES_DASHBOARD_DOMAIN=
JOSHU_HERMES_DASHBOARD_USER=admin
# Required on production boxes — Caddy basic auth + dashboard can read/write ~/.hermes/.env.
JOSHU_HERMES_DASHBOARD_PASSWORD=
# Hermes profile for Kanban worker dispatch (`hermes -p <assignee>`). Must exist (`hermes profile list`).
JOSHU_HERMES_KANBAN_ASSIGNEE=default
# Local dev only: skip Joshu basic-auth on the proxy.
# JOSHU_HERMES_DASHBOARD_ALLOW_INSECURE=true
HERMES_DASHBOARD_HOST=127.0.0.1
HERMES_DASHBOARD_PORT=9119
# Hermes config.yaml defaults (written by Joshu on gateway startup).
JOSHU_HERMES_MODEL=deepseek/deepseek-v4-flash
JOSHU_HERMES_PROVIDER=openrouter
JOSHU_HERMES_PLUGIN_NAMES=observability/langfuse
# skills.disabled: computed at gateway sync from integrations/hermes/skills-enabled.yaml allowlist
# + bundled Hermes discovery (HERMES_DIR=/opt/hermes-agent in image). Verify after upgrade:
#   python3 -c "import yaml; print(len(yaml.safe_load(open('/root/.hermes/config.yaml'))['skills']['disabled']))"
# JOSHU_HERMES_SKILLS_DISABLED=extra-skill-name
# HERMES_LANGFUSE_PUBLIC_KEY=          # from control-plane DEFAULT_* at provision
# HERMES_LANGFUSE_SECRET_KEY=
# HERMES_LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
# HERMES_LANGFUSE_ENV=production
# HERMES_LANGFUSE_USER_ID=voice-0531   # box slug — set by control plane per sandbox
# OpenRouter key for Hermes chat. Do not reuse a developer-local key in production.
OPENROUTER_API_KEY=
JOSHU_HINDSIGHT_ENABLED=true
JOSHU_HINDSIGHT_OPTIONAL=true
HINDSIGHT_API_URL=http://127.0.0.1:8888
HINDSIGHT_API_DATABASE_URL=postgresql://hindsight:hindsight@127.0.0.1:5432/hindsight
HINDSIGHT_API_LLM_PROVIDER=openrouter
HINDSIGHT_API_LLM_API_KEY=
HINDSIGHT_API_LLM_MODEL=google/gemini-3.1-flash-lite
HINDSIGHT_REQUIRE_EXTERNAL_ML=true
HINDSIGHT_API_EMBEDDINGS_PROVIDER=google
HINDSIGHT_API_EMBEDDINGS_GEMINI_API_KEY=
# Optional: place service-account files under /etc/joshu/secrets and reference
# the in-container path, for example /etc/joshu/secrets/google-reranker-service-account.json.
HINDSIGHT_API_RERANKER_PROVIDER=google
HINDSIGHT_API_RERANKER_GOOGLE_PROJECT_ID=
HINDSIGHT_API_RERANKER_GOOGLE_SERVICE_ACCOUNT_KEY=/etc/joshu/secrets/google-reranker-service-account.json

# --- File brain (gbrain) — always on; indexes Desktop; shares Hindsight embedding keys ---
GBRAIN_REF=fa2c7a6990a7a57b251979ef6e1988ff09529021
GBRAIN_HOME=/root/.gbrain
GBRAIN_SEARCH_MODE=balanced
# gbrain MCP HTTP (Hermes mcp-gbrain + File Brain REST inspect); started by vps-start.sh
GBRAIN_MCP_HTTP_URL=http://127.0.0.1:8794
GBRAIN_MCP_HTTP_PORT=8794
# Optional: empty-index auto-recovery (defaults shown)
# GBRAIN_EMPTY_INDEX_WATCHDOG_SEC=300
# GBRAIN_FULL_SYNC_COOLDOWN_SEC=1800
# GBRAIN_ENSURE_SOFT_WAIT_SEC=45

# --- Composio (Connectors → Hermes mcp-composio) ---
# OAuth tokens live in Composio cloud. Provision sets COMPOSIO_USER_ID=<customer-slug> (per box).
# ArozOS login stays JOSHU_AROZ_USER (owner email). Without COMPOSIO_USER_ID, same owner = shared Gmail.
# COMPOSIO_API_KEY=
# COMPOSIO_USER_ID=patrick
# JOSHU_COMPOSIO_FEATURED_TOOLKITS=gmail,github,slack,notion,googlecalendar

# --- Twilio (per customer) ---
# TWILIO_AUTH_TOKEN=
# TWILIO_MEDIA_STREAM_SECRET=
# TWILIO_VOICE_WEBHOOK_URL=https://customer.sandbox.example.com/joshu/api/twilio/voice/inbound
# TWILIO_THINK_PASSWORD=your-passphrase   # if set: phone calls must say this before think/Hermes is allowed
# TWILIO_OWNER_CALLER=+15551234567        # optional: owner caller id for owner/non-owner phone policy
# TWILIO_PHONE_SESSION_WARN_MS=60000      # spoken time warning
# TWILIO_PHONE_SESSION_HANGUP_MS=90000    # goodbye then hang up (disabled after passphrase)

# --- Voice (speech-to-speech) — OSS bootstrap enables voice-rt when JOSHU_VOICE_IMAGE_REF is set; GEMINI_API_KEY from Welcome ---
JOSHU_VOICE_MODE=legacy
JOSHU_WEB_VOICE_ENABLED=false
JOSHU_VOICE_PROVIDER=gemini_live       # gemini_live (OSS default) | openai
VOICE_REALTIME_URL=http://127.0.0.1:8792
JOSHU_HTTP_BASE_URL=http://127.0.0.1:8788/joshu
# GEMINI_API_KEY=   # Google AI key — browser mic + optional PSTN when voice enabled
# GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
# GEMINI_LIVE_VOICE=Kore
# OPENAI_API_KEY=   # only if JOSHU_VOICE_PROVIDER=openai
# OPENAI_REALTIME_MODEL=gpt-realtime-2
# OPENAI_REALTIME_VOICE=alloy

# --- Instance agent ---
INSTANCE_AGENT_POLL_SEC=30
# Post-recreate health wait (ms). Hermes MCP boot can exceed 5 min; default 600000 (10 min).
# INSTANCE_AGENT_HEALTH_WAIT_MS=600000
INSTANCE_AGENT_SIGNING_SECRET=
JOSHU_HEALTH_URL=http://127.0.0.1:8788/joshu/api/instance/health
JOSHU_COMPOSE_FILE=/opt/joshu/deploy/docker-compose.yml
JOSHU_COMPOSE_ENV_FILE=/etc/joshu/instance.env

# --- Caddy ---
ACME_EMAIL=ops@example.com

# --- Box snapshots (optional; set by control plane at provision) ---
# JOSHU_SNAPSHOT_GCS_BUCKET=aeon-joshu-box-snapshots
# JOSHU_SNAPSHOT_BOX_ID=owner@example.com   # same as JOSHU_AROZ_USER
# Auth via HINDSIGHT_API_RERANKER_GOOGLE_SERVICE_ACCOUNT_KEY on VPS.

# --- Nylas agent mailbox (jMail / Connectors) ---
# Set at provision via control plane DEFAULT_NYLAS_API_KEY → NYLAS_API_KEY on the VPS.
# See docs/nylas-agent-mailbox.md
# NYLAS_API_KEY=
# NYLAS_API_URI=https://api.us.nylas.com

# --- Action guard (approvals bot — separate from chat bot below) ---
# JOSHU_ACTION_GUARD_ENABLED=true
# JOSHU_ACTION_GUARD_TELEGRAM_BOT_TOKEN=
# JOSHU_ACTION_GUARD_TELEGRAM_ALLOWED_USERS=123456789
# JOSHU_COMPOSIO_MCP_GUARD_URL=http://127.0.0.1:8796

# --- Telegram 1:1 chat (Hermes messaging gateway — separate BotFather bot) ---
# Joshu syncs TELEGRAM_* into ~/.hermes/.env on gateway start. Long polling on VPS (no webhook required).
# See docs/hermes-customizations.md#telegram-11-chat-hermes-messaging-gateway
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USERS=123456789
# TELEGRAM_HOME_CHANNEL=123456789
# TELEGRAM_WEBHOOK_URL=
# TELEGRAM_WEBHOOK_SECRET=
