CAMOFOX_URL=http://localhost:9377
NOVNC_URL=http://localhost:6080
NOVNC_PROXY_TARGET=http://localhost:6080
NOVNC_CLIENT_PATH=/novnc

# Point this at the fresh Hermes checkout created earlier.
HERMES_BIN=/Users/danbenyamin/Documents/dev/hermes-agent/venv/bin/hermes
# HERMES_DIR optional locally — derived from HERMES_BIN for dashboard startup + skill denylist.
# VPS Docker image sets HERMES_DIR=/opt/hermes-agent explicitly.
HERMES_API_BASE_URL=http://127.0.0.1:8642
HERMES_API_KEY=change-me-local-dev
HERMES_API_AUTO_START=true
# Hermes Admin + Kanban: http://127.0.0.1:8788/joshu/hermes-admin/ (Joshu proxy → :9119).
# dev:arozos starts the dashboard; manual: bash scripts/start-hermes-dashboard.sh (loads this .env).
JOSHU_HERMES_DASHBOARD_ENABLED=true
JOSHU_HERMES_DASHBOARD_ALLOW_INSECURE=true
HERMES_DASHBOARD_PORT=9119
# Hermes LLM — local dev uses OpenRouter (verified). VPS sandboxes may default to Anthropic direct.
# https://openrouter.ai/docs/cookbook/coding-agents/hermes-integration
JOSHU_HERMES_PROVIDER=openrouter
JOSHU_HERMES_MODEL=deepseek/deepseek-v4-flash
# JOSHU_HERMES_SESSION_SEARCH_MODEL=google/gemini-3.1-flash-lite
OPENROUTER_API_KEY=sk-or-...
# Day 0 cold-start inference (Connectors → Connect apps → Analyze mail). Uses OpenRouter separately from Hermes chat.
# JOSHU_DAY0_MODEL=openai/gpt-5.4-nano
# EA scheduling classifier (defaults to JOSHU_DAY0_MODEL)
# JOSHU_EA_CLASSIFIER_MODEL=openai/gpt-5.4-nano
# JOSHU_EA_CLASSIFIER_DISABLED=true
# JOSHU_DAY0_MAX_TOKENS=16384
# JOSHU_DAY0_API_KEY=   # optional override; defaults to OPENROUTER_API_KEY
# JOSHU_DAY0_BASE_URL=https://openrouter.ai/api/v1
# Anthropic direct (optional fallback or VPS-style setup):
# JOSHU_HERMES_PROVIDER=anthropic
# JOSHU_HERMES_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=sk-ant-...

# Joshu-owned Hermes customizations. Skills are scanned as an external dir;
# project plugins under .hermes/plugins are discovered when this is true.
# JOSHU_HERMES_SKILLS_SEED_MODE=merge
# JOSHU_HERMES_SKILLS_MERGE_MODEL=google/gemini-3.1-flash-lite
JOSHU_HERMES_SKILLS_DIR=/Users/danbenyamin/Documents/dev/joshu/integrations/hermes/skills
# Allowlist: integrations/hermes/skills-enabled.yaml (bundled denylist computed at gateway sync; agent skills in ~/.hermes/skills stay enabled)
# JOSHU_HERMES_SKILLS_ENABLED=extra-skill-name
# JOSHU_HERMES_SKILLS_DISABLED=force-disable-skill-name
HERMES_ENABLE_PROJECT_PLUGINS=true
# Comma-separated plugin names to add to plugins.enabled before gateway start.
# JOSHU_HERMES_PLUGIN_NAMES=joshu-browser,joshu-desktop
JOSHU_HERMES_PLUGIN_NAMES=observability/langfuse,joshu-desktop

# Langfuse observability (Hermes plugin + Joshu deterministic LLM calls).
# Set in ~/.hermes/.env or here (Joshu syncs Hermes keys on gateway start).
# Joshu Day 0 / EA classifier reuse the same HERMES_LANGFUSE_* keys (or LANGFUSE_*).
# pip install langfuse  # in the Hermes venv: ${HERMES_BIN%/*}/../ or venv/bin/pip
# HERMES_LANGFUSE_PUBLIC_KEY=pk-lf-...
# HERMES_LANGFUSE_SECRET_KEY=sk-lf-...
# HERMES_LANGFUSE_BASE_URL=https://us.cloud.langfuse.com   # or https://cloud.langfuse.com (EU)
# HERMES_LANGFUSE_ENV=local
# HERMES_LANGFUSE_USER_ID=local-dev   # Langfuse Users view; VPS control plane sets box slug per sandbox
# LANGFUSE_PROJECT_ID=cmpk73brj096rad0fvx3uecdm   # UI URL /project/{id}/ — skill-evolution-review prefetch links

# Optional Hindsight memory. In auto mode, Joshu starts a local Hindsight API
# only when HINDSIGHT_API_LLM_* configuration is present. Hindsight stores memory
# in local PostgreSQL/pg0; the LLM backend may be hosted/OpenAI-compatible.
JOSHU_HINDSIGHT_ENABLED=auto

# OneNote (Microsoft Graph) — scripts/fetch-onenote-page.mjs
# MS_GRAPH_ACCESS_TOKEN=   # az account get-access-token --resource https://graph.microsoft.com --scope Notes.Read
# MS_GRAPH_CLIENT_ID=      # optional device-code login when token unset (Azure app registration, delegated Notes.Read)
# MS_GRAPH_TENANT_ID=consumers   # personal Microsoft account apps (default auto-retries common → consumers)

# Composio — jChat "Connect apps" + Hermes mcp-composio (Gmail, GitHub, Slack, …).
# OAuth tokens are stored by Composio; connect once in the browser, then the box keeps using them.
# Docs: docs/hermes-chat-arozos-app.md#composio-app-connections-gmail-github-slack-
# COMPOSIO_API_KEY=                         # https://app.composio.dev → project settings
# JOSHU_COMPOSIO_GMAIL_TOOLKIT_VERSION=20260506_01   # pin Composio Gmail toolkit (required for tools.execute)
# JOSHU_COMPOSIO_ONENOTE_TOOLKIT_VERSION=20260507_00 # pin Composio OneNote toolkit (scripts/fetch-onenote-page.mjs)
# OneNote has no Composio managed OAuth — create an auth config in app.composio.dev, then:
# JOSHU_COMPOSIO_ONENOTE_AUTH_CONFIG_ID=ac_...
# Or JSON map: JOSHU_COMPOSIO_AUTH_CONFIGS={"onenote":"ac_..."}
# JOSHU_COMPOSIO_SLACK_TOOLKIT_VERSION=             # optional pin for owner-channel Slack notifications
# JOSHU_COMPOSIO_FEATURED_TOOLKITS=gmail,github,slack,notion,googlecalendar,onenote
# COMPOSIO_USER_ID=                       # local override; VPS: control plane sets <customer-slug> at provision

# Owner 1:1 channel — write approvals + optional owner chat ingress (Connectors → Overview)
# JOSHU_OWNER_CHANNEL_PROVIDER=telegram       # or slack
# JOSHU_OWNER_CHANNEL_PUBLIC_URL=             # VPS: https://<slug>.box.joshu.me/joshu — Slack decide URL fallback
# JOSHU_OWNER_CHANNEL_TELEGRAM_WEBHOOK_SECRET=  # optional; defaults to JOSHU_ACTION_GUARD_TELEGRAM_WEBHOOK_SECRET
# JOSHU_OWNER_CHANNEL_SLACK_SIGNING_SECRET=   # Slack interactivity verification (optional; Y/N polling is primary)

# File brain (gbrain) — always on; pin in deploy/RELEASE.json (gbrainRef). Install locally: npm run gbrain:install
GBRAIN_HOME=.local/gbrain
GBRAIN_SEARCH_MODE=balanced
# gbrain MCP HTTP — Hermes (mcp-gbrain) + File Brain REST; start via dev-arozos / start-gbrain-mcp-http.sh
GBRAIN_MCP_HTTP_URL=http://127.0.0.1:8794
GBRAIN_MCP_HTTP_PORT=8794
# Periodic git commit + sync_brain (git root: AROZ_DATA/files/users/; seconds; 0 = fs watch / manual only)
GBRAIN_REINDEX_INTERVAL_SEC=900
# JOSHU_GBRAIN_GIT_ROOT=   # override gbrain git root (default: ${AROZ_DATA}/files/users)
# Connectors MCP (sync + send; mail search via gbrain on connectors/ markdown)
JOSHU_CONNECTORS_MCP_HTTP_URL=http://127.0.0.1:8795
JOSHU_CONNECTORS_MCP_PORT=8795
# JOSHU_MCP_SUPERVISOR=false   # disable in-process MCP restart loop (default on when unset)
# JOSHU_CONNECTORS_MCP_OPTIONAL=true   # when true, instance health ignores connectors MCP down
# VPS boot: JOSHU_DEFER_HERMES_GATEWAY_WARM=true is set by vps-start.sh — do not set locally unless debugging
# Action guard — owner Telegram approval for Hermes agent writes. See docs/agent-safety.md
# Configure in Safety desktop app, env, or .joshu/action-guard/policy.json
# JOSHU_MCP_TOOL_POLICY_ENABLED=true   # hard agent blocks (Gmail send, deletes, Nylas calendar writes); default on when unset
# JOSHU_TERMINAL_MAIL_GUARD=1          # block terminal nylas/curl mail bypass; default on when unset
# JOSHU_ACTION_GUARD_ENABLED=true
# JOSHU_ACTION_GUARD_BROWSER_GATE=true   # gate Camofox click/type/press; Hermes patch + gateway restart required
# JOSHU_ACTION_GUARD_TELEGRAM_BOT_TOKEN=
# JOSHU_ACTION_GUARD_TELEGRAM_ALLOWED_USERS=123456789   # comma-separated Telegram user IDs; /start + Approve/Deny
# JOSHU_ACTION_GUARD_TIMEOUT_MS=1800000
# JOSHU_ACTION_GUARD_TELEGRAM_WEBHOOK=true
# JOSHU_ACTION_GUARD_TELEGRAM_WEBHOOK_SECRET=
# Composio MCP guard proxy (Hermes → :8796 → Composio cloud when guard enabled)
JOSHU_COMPOSIO_MCP_GUARD_URL=http://127.0.0.1:8796
JOSHU_COMPOSIO_MCP_GUARD_PORT=8796
JOSHU_CONNECTORS_CRON=true
# JOSHU_HERMES_TOOLSETS=...   # default: mcp-gbrain, mcp-joshu-connectors, kanban, hermes-cli, browser; mcp-composio last when connected (composioHermesMcpPolicy.ts)
# ArozOS user files (local dev). VPS uses /var/lib/arozos.
AROZ_DATA=.local/arozos-data
JOSHU_FILES_DIR_NAME="joshu's files"
# Per-instance assistant persona (defaults: Patrick / Dan). Control plane can override via instance.env.
# JOSHU_NAME=Patrick
# JOSHU_OWNER_NAME=Dan
# JOSHU_IMAGE_URL=
# JOSHU_VOICE_ID=
# Hermes workspace scoping (auto-set from JOSHU_DESKTOP_ROOT when ArozOS paths resolve):
# terminal.cwd + HERMES_WRITE_SAFE_ROOT → ArozOS Desktop (blocks macOS ~/Desktop writes).
# JOSHU_HERMES_TERMINAL_CWD=/custom/path
# JOSHU_HERMES_WRITE_SAFE_ROOT=/custom/path
# GBRAIN_REF=   # optional override; default read from deploy/RELEASE.json
HINDSIGHT_API_URL=http://127.0.0.1:8888
# HINDSIGHT_API_BIN=/Users/danbenyamin/Documents/dev/hermes-agent/venv/bin/hindsight-api
# Hindsight LLM (retain/reflect) — OpenRouter; reuses OPENROUTER_API_KEY when HINDSIGHT_API_LLM_API_KEY unset
# HINDSIGHT_API_LLM_PROVIDER=openrouter
# HINDSIGHT_API_LLM_MODEL=google/gemini-3.1-flash-lite
# HINDSIGHT_API_LLM_API_KEY=your-openrouter-key
# The sandbox image installs Hindsight slim + embedded DB, so embeddings/reranking should be
# external there. Local full installs can omit these and use local defaults.
# HINDSIGHT_API_EMBEDDINGS_PROVIDER=openai
# HINDSIGHT_API_EMBEDDINGS_OPENAI_MODEL=text-embedding-3-small
# HINDSIGHT_API_EMBEDDINGS_OPENAI_API_KEY=your-key
# HINDSIGHT_API_EMBEDDINGS_PROVIDER=google
# HINDSIGHT_API_EMBEDDINGS_GEMINI_API_KEY=your-gemini-key
# HINDSIGHT_API_RERANKER_PROVIDER=cohere
# HINDSIGHT_API_RERANKER_COHERE_MODEL=rerank-english-v3.0
# HINDSIGHT_API_RERANKER_COHERE_API_KEY=your-key
# Alternative validated reranker options:
# HINDSIGHT_API_RERANKER_PROVIDER=google
# HINDSIGHT_API_RERANKER_GOOGLE_PROJECT_ID=your-gcp-project
# HINDSIGHT_API_RERANKER_GOOGLE_SERVICE_ACCOUNT_KEY=/path/to/service-account.json
# HINDSIGHT_API_RERANKER_PROVIDER=rrf
# HINDSIGHT_BANK_ID=joshu

# Hermes chat browser context: off | light (url+title) | full (a11y snapshot) | auto (default)
# JOSHU_HERMES_CHAT_BROWSER_SYNC=auto
HITL_CAMOFOX_USER_ID=hitl-camofox
HITL_CAMOFOX_SESSION_KEY=hitl-main
HITL_CAMOFOX_SINGLE_TAB=true
CAMOFOX_USER_ID=hitl-camofox
CAMOFOX_SESSION_KEY=hitl-main
CAMOFOX_ADOPT_EXISTING_TAB=true

CAMOFOX_AUTO_RESTART=true
CAMOFOX_CONTAINER=camofox-hitl
DOCKER_BIN=docker
CAMOFOX_RESTART_COOLDOWN_MS=15000

# These are consumed by the patched Camofox image / local checkout. They cannot
# change an already-running Docker container; recreate or restart Camofox after
# changing them.
VNC_RESOLUTION=1024x768
CAMOFOX_VIEWPORT_WIDTH=1024
CAMOFOX_VIEWPORT_HEIGHT=768
# Default page when Camofox has no tab or only about:blank
CAMOFOX_START_URL=https://news.google.com/
# Fingerprint Firefox rv: for sites that block Camoufox 135 (e.g. slack.com/signin). Set 0 to use binary UA.
CAMOFOX_FF_VERSION=139

# Decodo (or other) residential proxy for Camofox browser — endpoint:port dashboard style:
# PROXY_STRATEGY=round_robin
# PROXY_HOST=us.decodo.com
# PROXY_PORTS=10001-10010
# PROXY_USERNAME=
# PROXY_PASSWORD=
# Optional explicit proxy for MS Graph CLI (else uses PROXY_HOST / PROXY_BACKCONNECT_* above)
# MS_GRAPH_PROXY_URL=http://user:pass@host:port
# VPS: bash scripts/sync-camofox-proxy-to-vps.sh <slug>  (uses SYNC_BOX_SSH_HOST or <slug>.box.joshu.me — not HOST below)

# Docker container name (must match scripts/ensure-camofox-container.sh and Joshu CAMOFOX_AUTO_RESTART)
# CAMOFOX_CONTAINER=camofox-hitl

HOST=127.0.0.1
PORT=8787
# Joshu Express (Twilio webhook, APIs) — dev-arozos default 8788; do not confuse with PORT above (ArozOS)
# JOSHU_PORT=8788

# --- Twilio PSTN → Hermes Chat voice (optional) ---
# Requires public HTTPS + WSS (tunnel in dev). Webhook URL must match Twilio console exactly.
# TWILIO_AUTH_TOKEN=
# TWILIO_MEDIA_STREAM_SECRET=   # openssl rand -hex 32 (not base64 — +/= break WSS token query)
# TWILIO_VOICE_WEBHOOK_URL=https://your-host.example/joshu/api/twilio/voice/inbound
# Optional explicit stream URL (otherwise derived from TWILIO_VOICE_WEBHOOK_URL):
# TWILIO_MEDIA_STREAM_WSS_URL=wss://your-host.example/joshu/api/twilio/media-stream/<secret>  (path token; not ?token= for ngrok)
# TWILIO_PHONE_SYSTEM_PROMPT=You are Hermes on a phone call. Keep answers short and speakable.
# TWILIO_THINK_PASSWORD=your-passphrase   # if set: phone calls must say this before think/Hermes is allowed
# TWILIO_OWNER_CALLER=+15551234567        # optional: owner caller id for owner/non-owner phone policy
# TWILIO_PHONE_SESSION_WARN_MS=60000      # spoken time warning (non-owner / before passphrase)
# TWILIO_PHONE_SESSION_HANGUP_MS=90000    # goodbye then hang up (disabled after passphrase unlock)
# TWILIO_HERMES_MODEL=
# JOSHU_VOICE_MODE=realtime_s2s   # Speech-to-speech (phone + browser) — see docs/vps-sandbox/voice-realtime.md
# JOSHU_VOICE_PROVIDER=openai     # openai (default) | gemini_live (browser web voice)
# GEMINI_API_KEY=                 # required when JOSHU_VOICE_PROVIDER=gemini_live
# GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
# GEMINI_LIVE_VOICE=Kore
# JOSHU_WEB_VOICE_ENABLED=true
# VOICE_REALTIME_URL=http://127.0.0.1:8792
# VOICE_REALTIME_DEBUG=true   # full speech-instruct payloads + OpenAI events
# TWILIO_MEDIA_STREAM_SECRET=   # hex token for /voice-rt/media WSS (browser + Twilio)
# JOSHU_VOICE_WSS_HOST=127.0.0.1:8788   # ArozOS dev: browser WS connects to Joshu (8787 does not proxy voice)
# JOSHU_VOICE_WSS_PATH=/voice-rt/media
# JOSHU_VOICE_WSS_DIRECT=auto   # auto | true | false — VPS bootstrap sets false (see docs/vps-sandbox/web-voice.md)
# OPENAI_REALTIME_MODEL=gpt-realtime-2
# OPENAI_REALTIME_VOICE=alloy
# VOICE_HERMES_PROGRESS_FIRST_DELAY_MS=10000

# Leave empty for local dev at /. Set to e.g. /joshu when behind ArozOS subservice (VPS).
# PUBLIC_BASE_PATH=

# Source-built ArozOS inputs for npm run dev:arozos and VPS deploys.
# Product builds should use vendor/arozos (private mirror submodule).
# For one-off local ArozOS editing, set AROZOS_SOURCE_DIR to another checkout.
# AROZOS_REPO=https://github.com/tobychui/arozos.git
# AROZOS_REF=master
# AROZOS_SOURCE_DIR=/Users/danbenyamin/Documents/dev/arozos

# Deploy Hermes image input. Keep this pinned to a commit/tag with generic
# Camofox adopt_existing_tab support; The image build does not patch Hermes core.
# HERMES_AGENT_REPO=https://github.com/NousResearch/hermes-agent.git
# Hermes Agent v0.14.0 = tag v2026.5.16 (peeled commit below).
# HERMES_AGENT_REF=a91a57fa5a13d516c38b07a141a9ce8a3daabeb0

# Hermes voice / messaging (not read by Joshu directly — set in ~/.hermes/.env for
# the Hermes CLI/gateway, or pack into instance secrets HERMES_ENV_B64 for deploys).
# See docs/local-installation.md (Voice) and Hermes Voice Mode user guide.
# GROQ_API_KEY=                      # optional: fast cloud STT (set stt.provider: groq in config)
# VOICE_TOOLS_OPENAI_KEY=            # optional: OpenAI Whisper/TTS
# ELEVENLABS_API_KEY=                # optional: premium TTS
# DISCORD_BOT_TOKEN=
# DISCORD_ALLOWED_USERS=
# Telegram 1:1 chat via Hermes messaging gateway — **separate BotFather bot** from action-guard above.
# Joshu syncs these into ~/.hermes/.env on gateway start. VPS: also set in /etc/joshu/instance.env.
# See docs/hermes-customizations.md#telegram-11-chat-hermes-messaging-gateway
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USERS=123456789   # numeric Telegram user ID (not @username)
# TELEGRAM_HOME_CHANNEL=123456789
# TELEGRAM_WEBHOOK_URL=          # optional; VPS always-on can omit (long polling default)
# TELEGRAM_WEBHOOK_SECRET=
#
# Hermes Slack chat via Socket Mode — separate Slack app from Composio (tools) and owner approvals.
# Configure in Safety app → Hermes Slack chat, or set here / local-env.json. Joshu syncs on save.
# TELEGRAM_HOME_CHANNEL analog: SLACK_HOME_CHANNEL for cron delivery.
# SLACK_BOT_TOKEN=xoxb-…
# SLACK_APP_TOKEN=xapp-…
# SLACK_ALLOWED_USERS=U0123456789
# SLACK_HOME_CHANNEL=C01234567890
# SLACK_ALLOWED_CHANNELS=C01234567890

# Joshu connectors MCP HTTP (:8795 default)
# JOSHU_CONNECTORS_API_BASE=http://127.0.0.1:8788/joshu   # Joshu REST — NOT ArozOS :8787
# JOSHU_MCP_SUPERVISOR=true   # Joshu restarts dead MCP processes (default on)

# Nylas Agent Account mailbox (see docs/nylas-agent-mailbox.md)
# Local dev: dev-arozos loads this file; Joshu listens on JOSHU_PORT (default 8788).
# NYLAS_API_KEY=                            # local dev; VPS: DEFAULT_NYLAS_API_KEY in control-plane .env.local
# NYLAS_API_URI=https://api.us.nylas.com
# One-time per Nylas app if GET /v3/connectors/nylas returns connector.not_found:
#   curl -s -X POST "$NYLAS_API_URI/v3/connectors" -H "Authorization: Bearer $NYLAS_API_KEY" \
#     -H "Content-Type: application/json" -d '{"provider":"nylas"}'

# Excalidraw fork (vendor/excalidraw submodule only — no external local checkout).
# EXCALIDRAW_REPO=https://github.com/db-aeon/excalidraw.git
# EXCALIDRAW_REF=joshu-markdown-wysiwyg
# EXCALIDRAW_SOURCE_DIR=vendor/excalidraw
# EXCALIDRAW_PORT=3002
# EXCALIDRAW_HOST=127.0.0.1

# Box snapshots — durable storage (Google Cloud Storage)
# When configured, snaps upload to GCS; restore downloads from cloud on new boxes.
# JOSHU_SNAPSHOT_STORAGE=auto          # auto | gcs | local
# JOSHU_SNAPSHOT_GCS_BUCKET=aeon-joshu-box-snapshots
# JOSHU_SNAPSHOT_GCS_PREFIX=boxes/    # object key prefix (default: boxes/)
# JOSHU_SNAPSHOT_BOX_ID=my-box-slug    # per-box segment (default: JOSHU_INSTANCE_ID / JOSHU_AROZ_USER)
# JOSHU_SNAPSHOT_SHARED_BOX_ID=shared # shared snapshots restorable on any new box
# JOSHU_SNAPSHOT_GCS_KEY_FILE=/path/to/service-account.json
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# JOSHU_SNAPSHOT_LOCAL_CACHE=true      # keep .local/snapshots cache when using GCS
# JOSHU_SNAPSHOT_DIR=.local/snapshots  # local cache dir (gitignored)
