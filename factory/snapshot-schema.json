{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "JoshuBoxSnapshotManifest",
  "type": "object",
  "required": ["schemaVersion", "snapshotId", "createdAt", "releaseVersion", "joshuArozUser", "components"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "snapshotId": { "type": "string", "minLength": 1 },
    "label": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" },
    "releaseVersion": { "type": "string" },
    "joshuArozUser": { "type": "string" },
    "gbrainStrategy": { "enum": ["rebuild", "include"] },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "path", "sha256", "bytes"],
        "properties": {
          "name": { "type": "string" },
          "path": { "type": "string" },
          "sha256": { "type": "string" },
          "bytes": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
