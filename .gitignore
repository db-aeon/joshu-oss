# commit hashed app bundles dropped into the repo tree by local builds.
arozos/subservice/connectors/app/
arozos/web-overlays-vanilla/subservice/

# Local vendor checkouts only (gitlinks were removed from the OSS tree; keep clones private).
vendor/arozos/
vendor/excalidraw/

# Fleet SOP must not live in the AGPL tree (canonical under joshu/docs/Joshu-SOP/).
docs/Joshu-SOP/
